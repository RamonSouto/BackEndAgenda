{
  "name": "agenda-ajuste",
  "version": "1.0.0",
  "description": "Sistema de gerenciamento de agenda de ajustes pós-cirurgicos",
  "license": "ISC",
  "author": "Ramon David Souto",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "clean-uploads": "node scripts/cleanUploads.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration --coverage --runInBand",
    "test:e2e": "jest --testPathPattern=e2e --coverage --runInBand",
    "test:validation": "jest --testPathPattern=validation --coverage --runInBand",
    "test:auth": "jest --testPathPattern=auth --coverage --runInBand",
    "test:ci": "jest --coverage --ci --runInBand --maxWorkers=2",
    "test:coverage": "jest --coverage && open coverage/lcov-report/index.html"
  },
  "keywords": [
    "agenda",
    "ajustes",
    "cirurgia",
    "nodejs",
    "express",
    "mysql"
  ],
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@types/jest": "^29.5.8",
    "faker": "^5.5.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}